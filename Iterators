import java.util.ArrayList;
import java.util.Iterator;
public class iterator_learn {
    public static void main(String[] args) {

        ArrayList al = new ArrayList();
        al.add("java");
        al.add("is");
        al.add("fun");
        al.add("to");
        al.add("learn");

        Iterator i = al.iterator();
        while (i.hasNext()) {
            System.out.print(i.next() + " ");
        }
    }
}
