import java.util.ArrayList;

public class Arraylist_forEachLoop {
    static void main(String[] args) {
        ArrayList al = new ArrayList();
        al.add(10);
        al.add(20);
        al.add(30);
        al.add(40);
//because treated as objets
        for (Object i : al){
            System.out.println(i);
        }
    }
}
